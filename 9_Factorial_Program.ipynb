      "source": [
        "def factorial(n):\n",
        "    fact = 1\n",
        "    for i in range(1, n+1):\n",
        "        fact = fact * i\n",
        "    return fact\n",
        "\n",
        "n = int(input(\"Enter a number: \"))\n",
        "result = factorial(n)\n",
        "\n",
        "print(\"Factorial =\", result)"
      ]
    }
  ]
}