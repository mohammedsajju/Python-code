      "source": [
        "# Fibonacci Sequence\n",
        "n = int(input(\"Enter number of terms: \"))\n",
        "\n",
        "a = 0\n",
        "b = 1\n",
        "\n",
        "print(\"Fibonacci Sequence:\")\n",
        "for i in range(n):\n",
        "    print(a, end=\" \")\n",
        "    c = a + b\n",
        "    a = b\n",
        "    b = c"
      ]
    }
  ]
}